---
import FormattedDate from './FormattedDate.astro';

interface Props {
	href: string;
	title: string;
	dek: string;
	publishDate: Date;
	readingMinutes: number;
}

const { href, title, dek, publishDate, readingMinutes } = Astro.props;
---

<article class="post-card">
	<a href={href} class="card-link">
		<h2>{title}</h2>
		<p class="dek">{dek}</p>
	</a>
	<p class="meta ui">
		<FormattedDate date={publishDate} />
		<span aria-hidden="true">&middot;</span>
		<span>{readingMinutes} min read</span>
	</p>
</article>

<style>
	.post-card {
		padding: 1.75rem 0;
		border-bottom: 1px solid var(--rule);
	}

	.post-card:last-child {
		border-bottom: 0;
	}

	.card-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.card-link:hover h2 {
		color: var(--accent);
	}

	h2 {
		font-size: 1.5rem;
		margin: 0 0 0.4rem;
		line-height: 1.25;
		letter-spacing: -0.005em;
	}

	.dek {
		margin: 0 0 0.6rem;
		color: var(--ink-soft);
		font-style: italic;
		line-height: 1.5;
	}

	.meta {
		margin: 0;
		display: flex;
		gap: 0.5rem;
	}
</style>
